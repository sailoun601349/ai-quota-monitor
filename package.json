{
  "name": "ai-quota-monitor",
  "version": "2.2.0",
  "description": "A lightweight tray dashboard for monitoring AI service quotas, balances, and usage.",
  "main": "src/main/main.js",
  "author": "AI Quota Monitor Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable",
    "build:dir": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --dir"
  },
  "build": {
    "appId": "com.ai.quota.monitor",
    "productName": "AI Quota Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/icon.ico",
      "assets/icon.png",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "AIQuotaMonitor-V2.2.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
